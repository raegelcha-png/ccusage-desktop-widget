<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.raegalcha.ccusage-cache</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>/usr/local/bin/node /Users/raegalcha/.npm-global/lib/node_modules/ccusage/dist/index.js daily -j -O --since $(date -v-90d +%Y%m%d) > /Users/raegalcha/.ccusage-widget/data.json.tmp 2>/dev/null && mv /Users/raegalcha/.ccusage-widget/data.json.tmp /Users/raegalcha/.ccusage-widget/data.json</string>
    </array>
    <key>StartInterval</key>
    <integer>600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>/tmp/ccusage-cache.err</string>
    <key>StandardOutPath</key>
    <string>/tmp/ccusage-cache.out</string>
</dict>
</plist>
